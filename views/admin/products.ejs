    // FIXED: Properly handle validation errors vs session expiry
    async function fetchJson(url, opts = {}) {
      opts.credentials = opts.credentials || 'same-origin';
      opts.headers = opts.headers || {};
      opts.headers['Accept'] = opts.headers['Accept'] || 'application/json';
      const resp = await fetch(url, opts);

      if (!resp.ok) {
        const txt = await resp.text();
        try {
          const json = JSON.parse(txt);
          // If server sent JSON with a message, use it (validation error, not found, etc.)
          if (json && json.message) {
            throw new Error(json.message);
          }
          // Fallback for valid JSON without message
          throw new Error('Request failed');
        } catch (e) {
          // If it's a SyntaxError, JSON parsing failed → server sent HTML (session expired)
          if (e instanceof SyntaxError) {
            throw new Error('Session expired or unauthorized. Please login again.');
          }
          // Otherwise it's our thrown Error with a real validation/error message → re-throw it
          throw e;
        }
      }
      return resp.json();
    }
    /* === Open edit modal === */
    async function openEditModal(productId) {
      try {
        const data = await fetchJson(`/admin/products/${productId}`, { method: 'GET' });
        if (!data.success) throw new Error(data.message || 'Failed to load product');

        const product = data.product;
        document.getElementById('editProductId').value = product._id;
        document.getElementById('editProductName').value = product.productName;
        document.getElementById('editBrand').value = product.brand;
        document.getElementById('editCategory').value = product.category?._id || '';
        document.getElementById('editRegularPrice').value = product.regularPrice;
        document.getElementById('editSalesPrice').value = product.salesPrice;
        // productOffer is managed outside the add/edit forms; do not populate here
        document.getElementById('editQuantity').value = product.quantity;
        document.getElementById('editColor').value = product.color;
        document.getElementById('editDescription').value = product.description;

        const imagePreview = document.getElementById('editImagePreview');
        // initialize removedImages tracker
        window._removedImages = [];
        document.getElementById('removedImagesInput').value = '';

        imagePreview.innerHTML = (product.productImage || []).map((img, idx) => `
      <div class="w-20 h-20 relative" data-image-url="${img}">
        <img src="${img}" class="w-full h-full object-cover rounded">
        <button type="button" class="remove-image-btn absolute top-0 right-0 bg-red-600 text-white rounded-full text-xs w-6 h-6 flex items-center justify-center">&times;</button>
      </div>
    `).join('');

        // attach click handlers for remove buttons
        imagePreview.querySelectorAll('.remove-image-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const container = e.currentTarget.closest('[data-image-url]');
            if (!container) return;
            const url = container.getAttribute('data-image-url');
            // mark removed and remove from UI
            window._removedImages.push(url);
            document.getElementById('removedImagesInput').value = JSON.stringify(window._removedImages);
            container.remove();
          });
        });

        document.getElementById('editModal').classList.remove('hidden');
      } catch (err) {
        Swal.fire({ icon: 'error', title: 'Error!', text: err.message || 'Error loading product details' });
      }
    }

    /* === DELETE PRODUCT === */
    function confirmDelete(productId) {
      Swal.fire({
        title: 'Are you sure?',
        text: "This will permanently delete the product. You won't be able to revert this!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: 'Yes, delete it!'
      }).then((result) => {
        if (result.isConfirmed) {
          deleteProduct(productId);
        }
      });
    }

    async function deleteProduct(productId) {
      try {
        const data = await fetchJson(`/admin/products/${productId}`, { method: 'DELETE' });
        if (data.success) {
          Swal.fire({ icon: 'success', title: 'Deleted!', text: 'Product has been deleted.', showConfirmButton: false, timer: 1500 })
            .then(() => {
              const row = document.querySelector(`tr[data-product-id="${productId}"]`);
              if (row) row.remove(); else location.reload();
            });
        } else {
          throw new Error(data.message || 'Delete failed');
        }
      } catch (err) {
        Swal.fire({ icon: 'error', title: 'Error!', text: err.message || 'Error deleting product' });
      }
    }

    /* === ADD PRODUCT FORM === */
    const addForm = document.getElementById('addProductForm');
    if (addForm) {
      addForm.addEventListener('input', (e) => {
        if (e.target && e.target.name) {
          clearAddProductFieldError(e.target.name.charAt(0).toUpperCase() + e.target.name.slice(1));
        }
        clearAddProductErrors();
      });
      addForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearAddProductErrors();

        const form = e.target;
        const fieldErrors = {};
        const errors = [];
        const productName = form.elements.productName?.value?.trim();
        const brand = form.elements.brand?.value?.trim();
        const category = form.elements.category?.value?.trim();
        const regularPriceValue = form.elements.regularPrice?.value;
        const salesPriceValue = form.elements.salesPrice?.value;
        const quantityValue = form.elements.quantity?.value;
        const color = form.elements.color?.value?.trim();
        const description = form.elements.description?.value?.trim();
        const fileInput = form.querySelector('input[name="productImages"]');

        if (!productName) {
          fieldErrors.ProductName = 'Product Name is required.';
          errors.push(fieldErrors.ProductName);
        }
        if (!brand) {
          fieldErrors.Brand = 'Brand is required.';
          errors.push(fieldErrors.Brand);
        }
        if (!category) {
          fieldErrors.Category = 'Category is required.';
          errors.push(fieldErrors.Category);
        }
        if (!regularPriceValue) {
          fieldErrors.RegularPrice = 'Regular Price is required.';
          errors.push(fieldErrors.RegularPrice);
        }
        if (!salesPriceValue) {
          fieldErrors.SalesPrice = 'Sales Price is required.';
          errors.push(fieldErrors.SalesPrice);
        }
        if (!quantityValue) {
          fieldErrors.Quantity = 'Quantity is required.';
          errors.push(fieldErrors.Quantity);
        }
        if (!color) {
          fieldErrors.Color = 'Color is required.';
          errors.push(fieldErrors.Color);
        }
        if (!description) {
          fieldErrors.Description = 'Description is required.';
          errors.push(fieldErrors.Description);
        }

        const regularPrice = Number(regularPriceValue);
        if (regularPriceValue && (isNaN(regularPrice) || regularPrice < 0)) {
          fieldErrors.RegularPrice = 'Regular Price must be a valid non-negative number.';
          errors.push(fieldErrors.RegularPrice);
        }

        const salesPrice = Number(salesPriceValue);
        if (salesPriceValue && (isNaN(salesPrice) || salesPrice < 0)) {
          fieldErrors.SalesPrice = 'Sales Price must be a valid non-negative number.';
          errors.push(fieldErrors.SalesPrice);
        }

        const quantity = Number(quantityValue);
        if (quantityValue && (!Number.isInteger(quantity) || quantity < 0)) {
          fieldErrors.Quantity = 'Quantity must be a valid non-negative integer.';
          errors.push(fieldErrors.Quantity);
        }

        if (!fileInput?.files || fileInput.files.length === 0) {
          fieldErrors.ProductImages = 'Please upload at least one product image.';
          errors.push(fieldErrors.ProductImages);
        } else if (fileInput.files.length > 4) {
          fieldErrors.ProductImages = 'You can upload a maximum of 4 images.';
          errors.push(fieldErrors.ProductImages);
        } else {
          const invalidFiles = Array.from(fileInput.files).filter(file => !['image/jpeg', 'image/png', 'image/webp'].includes(file.type) || file.size > 5 * 1024 * 1024);
          if (invalidFiles.length > 0) {
            fieldErrors.ProductImages = invalidFiles.some(file => file.size > 5 * 1024 * 1024)
              ? 'Each image must be smaller than 5 MB.'
              : 'Only JPG, JPEG, PNG, and WEBP images are allowed.';
            errors.push(fieldErrors.ProductImages);
          }
        }

        if (errors.length) {
          Object.entries(fieldErrors).forEach(([field, message]) => showAddProductFieldError(field, message));
          showAddProductErrors(['Please fix the highlighted fields.']);
          return;
        }

        const formData = new FormData(form);
        try {
          const data = await fetchJson('/admin/products', { method: 'POST', body: formData });
          if (data.success) {
            Swal.fire({ icon: 'success', title: 'Success!', text: data.message, showConfirmButton: false, timer: 1500 })
              .then(() => location.reload());
          } else {
            showAddProductErrors([data.message || 'Add failed']);
          }
        } catch (err) {
          showAddProductErrors([err.message || 'Error adding product']);
        }
      });
    }

    /* === EDIT PRODUCT FORM === */
    const editForm = document.getElementById('editProductForm');
    if (editForm) {
      editForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearEditProductErrors();
        const productId = document.getElementById('editProductId').value;
        const formData = new FormData(e.target);

        const imageInput = e.target.querySelector('input[name="productImages"]');
        const existingImages = document.getElementById('editImagePreview').children.length;
        const newImages = imageInput?.files?.length || 0;
        if (existingImages + newImages < 1 && newImages > 0) {
          showEditProductErrors(['Please upload at least one product image.']);
          return;
        }
        if (existingImages + newImages > 4) {
          showEditProductErrors(['You can upload a maximum of 4 images.']);
          return;
        }
        if (imageInput?.files?.length > 0) {
          const invalidFiles = Array.from(imageInput.files).filter(file => !['image/jpeg', 'image/png', 'image/webp'].includes(file.type) || file.size > 5 * 1024 * 1024);
          if (invalidFiles.length > 0) {
            showEditProductErrors([invalidFiles.some(file => file.size > 5 * 1024 * 1024) ? 'Each image must be smaller than 5 MB.' : 'Only JPG, JPEG, PNG, and WEBP images are allowed.']);
            return;
          }
        }

        try {
          const data = await fetchJson(`/admin/products/${productId}`, { method: 'PUT', body: formData });
          if (data.success) {
            Swal.fire({ icon: 'success', title: 'Success!', text: data.message, showConfirmButton: false, timer: 1500 })
              .then(() => location.reload());
          } else throw new Error(data.message || 'Update failed');
        } catch (err) {
          showEditProductErrors([err.message || 'Error updating product']);
        }
      });
    }

    /* === BLOCK / UNBLOCK === */
    function confirmBlock(productId) {
      Swal.fire({
        title: 'Block Product?',
        text: "This product will be hidden from users!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: 'Yes, block it!'
      }).then((result) => {
        if (result.isConfirmed) blockProduct(productId);
      });
    }

    function confirmUnblock(productId) {
      Swal.fire({
        title: 'Unblock Product?',
        text: "This product will be visible to users again!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#28a745',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Yes, unblock it!'
      }).then((result) => {
        if (result.isConfirmed) unblockProduct(productId);
      });
    }

    async function blockProduct(productId) {
      try {
        const data = await fetchJson(`/admin/products/${productId}/block`, { method: 'PATCH' });
        if (data.success) {
          Swal.fire({ icon: 'success', title: 'Blocked!', text: data.message || 'Product blocked', showConfirmButton: false, timer: 1200 })
            .then(() => {
              // Update the button to show Unblock
              updateBlockButton(productId, true);
            });
        } else throw new Error(data.message || 'Block failed');
      } catch (err) {
        Swal.fire({ icon: 'error', title: 'Error!', text: err.message || 'Error blocking product' });
      }
    }

    async function unblockProduct(productId) {
      try {
        const data = await fetchJson(`/admin/products/${productId}/unblock`, { method: 'PATCH' });
        if (data.success) {
          Swal.fire({ icon: 'success', title: 'Unblocked!', text: data.message || 'Product unblocked', showConfirmButton: false, timer: 1200 })
            .then(() => {
              // Update the button to show Block
              updateBlockButton(productId, false);
            });
        } else throw new Error(data.message || 'Unblock failed');
      } catch (err) {
        Swal.fire({ icon: 'error', title: 'Error!', text: err.message || 'Error unblocking product' });
      }
    }

    function updateBlockButton(productId, isBlocked) {
      const row = document.querySelector(`tr[data-product-id="${productId}"]`);
      if (!row) return;

      const actionsCell = row.querySelector('td:last-child');
      const blockButton = actionsCell.querySelector('button:nth-child(2)'); // The block/unblock button is the second button

      if (isBlocked) {
        blockButton.textContent = 'Unblock';
        blockButton.className = 'text-green-600 hover:text-green-900 mr-3';
        blockButton.setAttribute('onclick', `confirmUnblock('${productId}')`);
      } else {
        blockButton.textContent = 'Block';
        blockButton.className = 'text-red-600 hover:text-red-900 mr-3';
        blockButton.setAttribute('onclick', `confirmBlock('${productId}')`);
      }
    }

    /* === PRODUCT OFFER (Set / Remove) === */
    async function promptSetOffer(productId) {
      const { value: formValues } = await Swal.fire({
        title: 'Set Product Offer',
        html: `
          <input type="number" id="offerInput" class="swal2-input" placeholder="Percentage (0-100)" min="0" max="100">
          <input type="date" id="startInput" class="swal2-input" placeholder="Start date">
          <input type="date" id="endInput" class="swal2-input" placeholder="End date">
        `,
        focusConfirm: false,
        showCancelButton: true,
        confirmButtonText: 'Set Offer',
        preConfirm: () => {
          const offerVal = Number(document.getElementById('offerInput').value);
          const startVal = document.getElementById('startInput').value;
          const endVal = document.getElementById('endInput').value;
          if (isNaN(offerVal) || offerVal < 0 || offerVal > 100) {
            Swal.showValidationMessage('Offer percentage must be between 0 and 100');
            return;
          }
          if (!startVal || !endVal) {
            Swal.showValidationMessage('Please select both start and end dates');
            return;
          }
          if (new Date(startVal) > new Date(endVal)) {
            Swal.showValidationMessage('End date must be after start date');
            return;
          }
          return { offer: offerVal, startDate: startVal, endDate: endVal };
        }
      });

      if (!formValues) return;
      const { offer, startDate, endDate } = formValues;

      try {
        const data = await fetchJson(`/admin/products/${productId}/offer`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ offer, startDate, endDate })
        });
        if (data.success) {
          Swal.fire({ icon: 'success', title: 'Offer Set', text: data.message || 'Offer updated' })
            .then(() => location.reload());
        } else throw new Error(data.message || 'Failed to set offer');
      } catch (err) {
        Swal.fire({ icon: 'error', title: 'Error', text: err.message || 'Failed to set offer' });
      }
    }

    async function confirmRemoveOffer(productId) {
      const res = await Swal.fire({
        title: 'Remove Offer?',
        text: 'This will remove any discount applied to the product.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Yes, remove',
        cancelButtonText: 'Keep'
      });
      if (!res.isConfirmed) return;

      try {
        const data = await fetchJson(`/admin/products/${productId}/offer/remove`, { method: 'PATCH' });
        if (data.success) {
          Swal.fire({ icon: 'success', title: 'Removed', text: data.message || 'Offer removed' })
            .then(() => location.reload());
        } else throw new Error(data.message || 'Failed to remove offer');
      } catch (err) {
        Swal.fire({ icon: 'error', title: 'Error', text: err.message || 'Failed to remove offer' });
      }
    }

    async function editProductOffer(id, percentage, startDate, endDate) {
      document.getElementById('editProductOfferModal').classList.remove('hidden');
      document.getElementById('editProductOfferId').value = id;
      document.getElementById('editOfferPercentage').value = percentage;
      document.getElementById('editOfferStartDate').value = startDate ? new Date(startDate).toISOString().split('T')[0] : '';
      document.getElementById('editOfferEndDate').value = endDate ? new Date(endDate).toISOString().split('T')[0] : '';
    }

    function closeEditProductOfferModal() {
      document.getElementById('editProductOfferModal').classList.add('hidden');
      document.getElementById('editProductOfferForm').reset();
    }

    document.getElementById('editProductOfferForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const id = document.getElementById('editProductOfferId').value;
      const formData = new FormData(e.target);
      
      try {
        const response = await fetch(`/admin/products/${id}/offer`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            percentage: formData.get('percentage'),
            startDate: formData.get('startDate'),
            endDate: formData.get('endDate')
          })
        });
        
        const data = await response.json();
        
        if (data.success) {
          closeEditProductOfferModal();
          window.location.reload();
        } else {
          Swal.fire({ icon: 'error', title: data.message || 'Error', timer: 2000 });
        }
      } catch (error) {
        Swal.fire({ icon: 'error', title: 'Error updating offer' });
      }
    });
  </script>

