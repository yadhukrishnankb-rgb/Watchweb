<div class="card">
<div class="card-header">
<span class="card-title">Order status</span>
</div>
<div style="display:flex;flex-direction:column;gap:14px;margin-top:4px;">
<div style="display:flex;align-items:center;gap:10px;font-size:13px;">
<div style="flex:1;color:#6b7280;">Completed</div>
<div class="progress-bar-bg"><div class="progress-bar-fill" style="width:65%;background:#16a34a;"></div></div>
<div style="min-width:32px;text-align:right;font-weight:600;color:#111827;">65%</div>
</div>
<div style="display:flex;align-items:center;gap:10px;font-size:13px;">
<div style="flex:1;color:#6b7280;">Processing</div>
<div class="progress-bar-bg"><div class="progress-bar-fill" style="width:20%;background:#f59e0b;"></div></div>
<div style="min-width:32px;text-align:right;font-weight:600;color:#111827;">20%</div>
</div>
<div style="display:flex;align-items:center;gap:10px;font-size:13px;">
<div style="flex:1;color:#6b7280;">Shipped</div>
<div class="progress-bar-bg"><div class="progress-bar-fill" style="width:10%;background:#3b82f6;"></div></div>
<div style="min-width:32px;text-align:right;font-weight:600;color:#111827;">10%</div>
</div>
<div style="display:flex;align-items:center;gap:10px;font-size:13px;">
<div style="flex:1;color:#6b7280;">Cancelled</div>
<div class="progress-bar-bg"><div class="progress-bar-fill" style="width:5%;background:#ef4444;"></div></div>
<div style="min-width:32px;text-align:right;font-weight:600;color:#111827;">5%</div>
</div>
</div>
</div>

</div>

<!-- Top selling products and categories -->
<div class="section-grid">
  <div class="card">
    <div class="card-header">
      <span class="card-title">Best-selling products</span>
    </div>
    <div class="top-list">
      <% if (topProducts.length === 0) { %>
        <div class="list-item"><span class="list-name">No delivered sales yet</span></div>
      <% } else { %>
        <% topProducts.forEach(function(item, idx) { %>
          <div class="list-item">
            <div style="display:flex;align-items:center;gap:10px;">
              <span class="list-rank"><%= idx + 1 %>.</span>
              <span class="list-name"><%= item.name %></span>
            </div>
            <div class="list-meta"><%= item.quantity %> sold</div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <span class="card-title">Best-selling categories</span>
    </div>
    <div class="top-list">
      <% if (topCategories.length === 0) { %>
        <div class="list-item"><span class="list-name">No category sales yet</span></div>
      <% } else { %>
        <% topCategories.forEach(function(item, idx) { %>
          <div class="list-item">
            <div style="display:flex;align-items:center;gap:10px;">
              <span class="list-rank"><%= idx + 1 %>.</span>
              <span class="list-name"><%= item.name %></span>
            </div>
            <div class="list-meta"><%= item.quantity %> sold</div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <span class="card-title">Best-selling brands</span>
    </div>
    <div class="top-list">
      <% if (topBrands.length === 0) { %>
        <div class="list-item"><span class="list-name">No brand sales yet</span></div>
      <% } else { %>
        <% topBrands.forEach(function(item, idx) { %>
          <div class="list-item">
            <div style="display:flex;align-items:center;gap:10px;">
              <span class="list-rank"><%= idx + 1 %>.</span>
              <span class="list-name"><%= item.name %></span>
            </div>
            <div class="list-meta"><%= item.quantity %> sold</div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>

