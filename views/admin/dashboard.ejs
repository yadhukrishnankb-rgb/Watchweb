<%- include("../../views/partials/admin/header") %>

<style>
* { box-sizing: border-box; }
.dash { padding: 2rem 1rem 3rem; background: #f3f4f6; min-height: 100vh; }
.dash-inner { max-width: 1240px; margin: 0 auto; }
.dashboard-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; margin-bottom: 1.8rem; flex-wrap: wrap; }
.dashboard-title { font-size: 2rem; font-weight: 700; color: #111827; margin: 0; }
.dashboard-subtitle { font-size: 0.95rem; color: #6b7280; margin: 0.35rem 0 0; }
.dashboard-meta { display: flex; align-items: center; gap: 12px; font-size: 0.9rem; color: #4b5563; }
.dashboard-meta span { background: #fff; border: 1px solid #e5e7eb; border-radius: 999px; padding: 0.5rem 0.85rem; }
.stat-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 16px; margin-bottom: 1.8rem; }
.stat-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 18px; padding: 1.3rem 1.5rem; position: relative; box-shadow: 0 18px 50px rgba(15, 23, 42, 0.06); transition: transform 0.2s ease, box-shadow 0.2s ease; }
.stat-card:hover { transform: translateY(-2px); box-shadow: 0 22px 60px rgba(15, 23, 42, 0.08); }
.stat-label { font-size: 12px; color: #6b7280; margin-bottom: 0.45rem; letter-spacing: 0.08em; text-transform: uppercase; }
.stat-value { font-size: 2rem; font-weight: 700; color: #111827; line-height: 1.05; }
.stat-change { font-size: 0.85rem; margin-top: 0.65rem; }
.pos { color: #16a34a; }
.neg { color: #dc2626; }
.stat-icon { width: 44px; height: 44px; border-radius: 14px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.stat-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; }
.badge-red { position: absolute; top: 14px; right: 14px; background: #fee2e2; color: #dc2626; font-size: 11px; padding: 4px 10px; border-radius: 999px; font-weight: 600; }
.section-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 18px; margin-bottom: 1.8rem; }
.card { background: #fff; border: 1px solid #e5e7eb; border-radius: 22px; padding: 1.5rem; box-shadow: 0 18px 50px rgba(15, 23, 42, 0.05); }
.card-header { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 1.25rem; }
.card-title { font-size: 1.05rem; font-weight: 700; color: #111827; }
.view-all { font-size: 0.9rem; color: #3b82f6; text-decoration: none; }
.view-all:hover { text-decoration: underline; }
.filter-controls { display: flex; gap: 10px; flex-wrap: wrap; }
.filter-btn { border: 1px solid #e5e7eb; border-radius: 999px; padding: 0.65rem 1rem; font-size: 0.8rem; color: #4b5563; text-decoration: none; background: #fff; transition: all 0.2s ease; }
.filter-btn.active { border-color: #3b82f6; color: #1d4ed8; background: #dbeafe; }
.filter-btn:hover { background: #f8fafc; }
.sales-summary { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; margin-top: 1rem; }
.summary-card { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 18px; padding: 1rem 1.2rem; box-shadow: 0 8px 20px rgba(15, 23, 42, 0.05); }
.summary-card span { display: block; font-size: 0.75rem; color: #6b7280; margin-bottom: 0.45rem; text-transform: uppercase; letter-spacing: 0.12em; }
.summary-card strong { display: block; font-size: 1.35rem; color: #111827; }
.sales-overview-meta { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; width: 100%; }
.range-title { font-size: 0.95rem; color: #6b7280; }
.top-list { display: grid; gap: 10px; }
.list-item { display: flex; justify-content: space-between; align-items: center; padding: 14px 0; border-bottom: 1px solid #f3f4f6; }
.list-item:last-child { border-bottom: none; }
.list-rank { font-size: 0.85rem; color: #6b7280; width: 30px; }
.list-name { font-size: 0.95rem; font-weight: 600; color: #111827; }
.list-meta { font-size: 0.85rem; color: #6b7280; }
table { width: 100%; border-collapse: collapse; font-size: 0.92rem; }
th { font-size: 0.78rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.08em; padding: 12px 14px; background: #f9fafb; text-align: left; }
th:first-child { border-radius: 8px 0 0 8px; }
th:last-child { border-radius: 0 8px 8px 0; }
td { padding: 14px 14px; border-bottom: 1px solid #f3f4f6; color: #111827; }
tr:last-child td { border-bottom: none; }
.status-pill { font-size: 0.75rem; padding: 4px 12px; border-radius: 999px; font-weight: 700; display: inline-block; }
.s-complete { background: #dcfce7; color: #15803d; }
.s-process { background: #fef9c3; color: #b45309; }
.s-shipped { background: #dbeafe; color: #1d4ed8; }
.s-cancel { background: #fee2e2; color: #b91c1c; }
.action-link { color: #3b82f6; font-size: 0.85rem; text-decoration: none; }
.action-link:hover { text-decoration: underline; }
.prod-row { display: flex; align-items: center; gap: 14px; padding: 14px 0; border-bottom: 1px solid #f3f4f6; }
.prod-row:last-child { border-bottom: none; }
.prod-img { width: 48px; height: 48px; border-radius: 12px; background: #f3f4f6; border: 1px solid #e5e7eb; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
.prod-name { font-size: 0.95rem; font-weight: 600; color: #111827; }
.prod-sku { font-size: 0.8rem; color: #9ca3af; margin-top: 2px; }
.prod-price { font-size: 0.95rem; font-weight: 700; color: #111827; text-align: right; }
.in-stock { font-size: 0.8rem; color: #16a34a; text-align: right; margin-top: 2px; }
.cust-row { display: flex; align-items: center; gap: 14px; padding: 14px 0; border-bottom: 1px solid #f3f4f6; }
.cust-row:last-child { border-bottom: none; }
.avatar { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; font-weight: 700; flex-shrink: 0; }
.av-1 { background: #dbeafe; color: #1d4ed8; }
.av-2 { background: #dcfce7; color: #15803d; }
.av-3 { background: #fef9c3; color: #b45309; }
.av-4 { background: #ede9fe; color: #6d28d9; }
.cust-name { font-size: 0.95rem; font-weight: 600; color: #111827; }
.cust-email { font-size: 0.8rem; color: #9ca3af; margin-top: 2px; }
.cust-orders { font-size: 0.95rem; font-weight: 700; color: #111827; text-align: right; }
.cust-joined { font-size: 0.8rem; color: #9ca3af; text-align: right; margin-top: 2px; }
.low-stock-banner { background: #fff5f5; border: 1px solid #fecaca; border-radius: 16px; padding: 1.4rem 1.5rem; margin-top: 1.5rem; }
.low-stock-title { font-size: 1rem; font-weight: 700; color: #b91c1c; margin-bottom: 0.8rem; }
.low-stock-item { display: flex; justify-content: space-between; font-size: 0.95rem; padding: 6px 0; color: #374151; }
.low-qty { color: #dc2626; font-weight: 700; }
.manage-link { font-size: 0.95rem; color: #dc2626; text-decoration: none; display: inline-block; margin-top: 1rem; }
.manage-link:hover { text-decoration: underline; }
.chart-wrap { min-height: 320px; background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%); border-radius: 22px; display: flex; align-items: flex-end; gap: 10px; padding: 20px 18px 38px; position: relative; overflow: hidden; border: 1px solid #e5e7eb; }
.chart-wrap::before { content: ''; position: absolute; left: 18px; right: 18px; bottom: 34px; height: 1px; background: #e5e7eb; }
.chart-wrap canvas { width: 100% !important; height: auto !important; }
.bar { flex: 1; border-radius: 10px 10px 0 0; background: #dbeafe; min-height: 24px; transition: background 0.2s ease; }
.bar:hover { background: #93c5fd; }
.bar.accent { background: #3b82f6; }
.chart-labels { position: absolute; bottom: 10px; left: 18px; right: 18px; display: flex; gap: 10px; }
.cl { flex: 1; text-align: center; font-size: 0.8rem; color: #6b7280; }
.chart-note { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; margin-top: 1.2rem; font-size: 0.95rem; color: #6b7280; }
.chart-note span { display: inline-flex; align-items: center; gap: 8px; }
.chart-dot { width: 10px; height: 10px; border-radius: 999px; display: inline-block; }
.chart-dot.primary { background: #3b82f6; }
.chart-dot.secondary { background: #bfdbfe; }
.progress-bar-bg { flex: 3; background: #f3f4f6; border-radius: 999px; height: 10px; overflow: hidden; }
.progress-bar-fill { height: 100%; border-radius: 999px; }
@media (max-width: 900px) {
  .stat-grid { grid-template-columns: 1fr 1fr; }
  .section-grid { grid-template-columns: 1fr; }
  .dashboard-meta { width: 100%; justify-content: flex-start; }
}
@media (max-width: 500px) {
  .stat-grid { grid-template-columns: 1fr; }
  .dashboard-header { align-items: flex-start; }
  .card { padding: 1.2rem; }
}
</style>

