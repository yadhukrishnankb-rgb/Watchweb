<!-- views/admin/orders.ejs -->
<%- include('../partials/admin/header') %>
<link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">

<style>
  .status-badge { @apply px-2 py-1 text-xs font-medium rounded; }
  .pending { @apply bg-yellow-100 text-yellow-800; }
  .processing { @apply bg-blue-100 text-blue-800; }
  .shipped { @apply bg-purple-100 text-purple-800; }
  .delivered { @apply bg-green-100 text-green-800; }
  .cancelled { @apply bg-red-100 text-red-800; }


  

</style>

<main class="p-6 bg-gray-50 min-h-screen">
  <div class="max-w-7xl mx-auto">
    <h1 class="text-3xl font-bold mb-6">Order Management</h1>

    <div class="mb-4">
      <a href="/admin/requests" class="px-4 py-2 bg-blue-600 text-white rounded">
        Return Requests
      </a>
    </div>

    <form method="GET" class="bg-white p-4 rounded shadow mb-6 flex flex-wrap gap-3">
      <input name="search" value="<%= search %>" placeholder="Search Order ID / User" class="px-3 py-2 border rounded flex-1 min-w-64">
      <select name="status" class="px-3 py-2 border rounded">
        <% statusOptions.forEach(o => { %>
          <option value="<%= o.value %>" <%= o.value === statusFilter ? 'selected' : '' %>><%= o.label %></option>
        <% }) %>
      </select>
      <button class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">Search</button>
      <% if (hasSearch) { %>
        <a href="/admin/orders" class="px-4 py-2 bg-gray-600 text-white rounded">Clear</a>
      <% } %>
    </form>

    <div class="bg-white rounded shadow overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Order ID</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Customer</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Amount</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
        <% orders.forEach(order => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm font-medium">
                <%= (order.orderId || 'N/A').slice(0, 8) %>...
              </td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= new Date(order.createdOn).toLocaleDateString() %></td>
              <td class="px-6 py-4 text-sm">
                <%= (order.user?.name) ? order.user.name : (order.address?.fullName || order.address?.name || 'N/A') %>
              </td>
              <td class="px-6 py-4 text-sm font-bold">₹<%= order.finalAmount.toLocaleString() %></td>
              <td class="px-6 py-4">
                <span class="status-badge <%= order.status.toLowerCase().replace(/\s/g,'-') %>">
                  <%= order.status %>
                </span>
              </td>
              <td class="px-6 py-4">
                <a href="/admin/orders/<%= order._id %>" class="text-blue-600 hover:underline">View</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) {
         const maxPagesToShow = 5;
         let startPage = Math.max(1, currentPage - Math.floor(maxPagesToShow / 2));
         let endPage = Math.min(totalPages, startPage + maxPagesToShow - 1);
         if (endPage - startPage + 1 < maxPagesToShow) {
           startPage = Math.max(1, endPage - maxPagesToShow + 1);
         }
    %>
      <nav aria-label="Orders pagination" class="mt-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between bg-white border border-gray-200 rounded-xl px-4 py-3 shadow-sm">
          <div class="text-sm text-gray-600">
            Showing page <span class="font-semibold text-gray-900"><%= currentPage %></span> of <span class="font-semibold text-gray-900"><%= totalPages %></span>
          </div>

          <div class="flex flex-wrap items-center gap-2">
            <a href="/admin/orders?page=<%= Math.max(currentPage - 1, 1) %>&search=<%= search %>&status=<%= statusFilter %>"
               class="px-3 py-2 rounded border text-sm <%= currentPage === 1 ? 'bg-gray-100 text-gray-400 pointer-events-none' : 'bg-white text-gray-700 hover:bg-gray-50' %>">
              Previous
            </a>

            <% if (startPage > 1) { %>
              <a href="/admin/orders?page=1&search=<%= search %>&status=<%= statusFilter %>"
                 class="px-3 py-2 rounded border bg-white text-gray-700 hover:bg-gray-50 text-sm">
                1
              </a>
              <% if (startPage > 2) { %>
                <span class="px-2 text-sm text-gray-500">…</span>
              <% } %>
            <% } %>

            <% for (let i = startPage; i <= endPage; i++) { %>
              <a href="/admin/orders?page=<%= i %>&search=<%= search %>&status=<%= statusFilter %>"
                 class="px-3 py-2 rounded border text-sm <%= i === currentPage ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-gray-700 hover:bg-gray-50' %>">
                <%= i %>
              </a>
            <% } %>

            <% if (endPage < totalPages) { %>
              <% if (endPage < totalPages - 1) { %>
                <span class="px-2 text-sm text-gray-500">…</span>
              <% } %>
              <a href="/admin/orders?page=<%= totalPages %>&search=<%= search %>&status=<%= statusFilter %>"
                 class="px-3 py-2 rounded border bg-white text-gray-700 hover:bg-gray-50 text-sm">
                <%= totalPages %>
              </a>
            <% } %>

            <a href="/admin/orders?page=<%= Math.min(currentPage + 1, totalPages) %>&search=<%= search %>&status=<%= statusFilter %>"
               class="px-3 py-2 rounded border text-sm <%= currentPage === totalPages ? 'bg-gray-100 text-gray-400 pointer-events-none' : 'bg-white text-gray-700 hover:bg-gray-50' %>">
              Next
            </a>
          </div>
        </div>
      </nav>
    <% } %>
  </div>
</main>
<%- include('../partials/admin/footer') %>