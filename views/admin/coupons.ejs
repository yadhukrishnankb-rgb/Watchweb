<%- include('../partials/admin/header') %>

<div class="flex-1 p-8">
  <div class="mb-6 flex justify-between items-center">
    <h1 class="text-2xl font-bold text-gray-800">Coupon Management</h1>
    <button onclick="openAddCouponModal()" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600">
      Create Coupon
    </button>
  </div>

  <!-- Coupons Table -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="px-6 py-4 border-b flex justify-between items-center">
      <h2 class="text-lg font-semibold">All Coupons</h2>
      <small class="text-gray-500">Showing <%= coupons.length %> coupons</small>
    </div>
    
    <% if (coupons.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Code</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Value</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Min Order</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Max Discount</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Expiry Date</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Used / Limit</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% coupons.forEach(coupon => { %>
              <tr class="hover:bg-gray-50" data-coupon-id="<%= coupon._id %>">
                <td class="px-6 py-4 text-sm font-semibold text-gray-900"><%= coupon.code %></td>
                <td class="px-6 py-4 text-sm text-gray-700">
                  <span class="<%= coupon.discountType === 'percentage' ? 'text-blue-600' : 'text-green-600' %>">
                    <%= coupon.discountType === 'percentage' ? 'Percentage' : 'Fixed' %>
                  </span>
                </td>
                <td class="px-6 py-4 text-sm font-medium text-gray-900">
                  <%= coupon.discountValue %><%= coupon.discountType === 'percentage' ? '%' : '₹' %>
                </td>
                <td class="px-6 py-4 text-sm text-gray-700">₹<%= coupon.minAmount.toLocaleString() %></td>
                <td class="px-6 py-4 text-sm text-gray-700">
                  <%= coupon.maxDiscount ? '₹' + coupon.maxDiscount.toLocaleString() : '-' %>
                </td>
                <td class="px-6 py-4 text-sm text-gray-700">
                  <%= new Date(coupon.expiryDate).toLocaleDateString('en-IN') %>
                  <% if (new Date(coupon.expiryDate) < new Date()) { %>
                    <span class="ml-2 inline-block bg-gray-500 text-white text-xs px-2 py-1 rounded">Expired</span>
                  <% } %>
                </td>
                <td class="px-6 py-4 text-sm text-gray-700"><%= coupon.usedCount %> / <%= coupon.usageLimit || '∞' %></td>
                <td class="px-6 py-4 text-sm">
                  <% if (coupon.isActive) { %>
                    <span class="inline-block bg-green-100 text-green-800 text-xs px-3 py-1 rounded-full font-semibold">Active</span>
                  <% } else { %>
                    <span class="inline-block bg-red-100 text-red-800 text-xs px-3 py-1 rounded-full font-semibold">Inactive</span>
                  <% } %>
                </td>
                <td class="px-6 py-4 text-sm whitespace-nowrap">
                  <button onclick="openEditCouponModal('<%= coupon._id %>', '<%= coupon.code %>', '<%= coupon.discountType %>', <%= coupon.discountValue %>, <%= coupon.minAmount %>, <%= coupon.maxDiscount || 'null' %>, '<%= coupon.expiryDate.toISOString().split('T')[0] %>', <%= coupon.usageLimit || 'null' %>, <%= coupon.userUsageLimit %>)" class="text-blue-600 hover:text-blue-900 mr-4">Edit</button>
                  <button onclick="toggleCoupon('<%= coupon._id %>', <%= !coupon.isActive %>)" class="<%= coupon.isActive ? 'text-red-600 hover:text-red-900' : 'text-green-600 hover:text-green-900' %> mr-4">
                    <%= coupon.isActive ? 'Deactivate' : 'Activate' %>
                  </button>
                  <button onclick="deleteCoupon('<%= coupon._id %>')" class="text-red-600 hover:text-red-900">Delete</button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="px-6 py-12 text-center text-gray-500">
        <p class="text-lg mb-2">No coupons found</p>
        <p>Create your first coupon by clicking the "Create Coupon" button above.</p>
      </div>
    <% } %>
  </div>
</div>

<!-- Create Coupon Modal -->
<div id="addCouponModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full">
  <div class="relative top-20 mx-auto p-5 border w-[600px] shadow-lg rounded-md bg-white">
    <div class="mt-3">
      <h3 class="text-lg leading-6 font-medium text-gray-900">Create New Coupon</h3>
      <form id="createCouponForm" class="mt-4">
        <div class="grid grid-cols-2 gap-4">
          <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Coupon Code*</label>
            <input type="text" name="code" required class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" placeholder="SUMMER25">
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Discount Type*</label>
            <select name="discountType" required class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
              <option value="fixed">Fixed Amount</option>
              <option value="percentage">Percentage (%)</option>
            </select>
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Discount Value*</label>
            <input type="number" name="discountValue" required min="1" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Minimum Order (₹)*</label>
            <input type="number" name="minAmount" required min="0" value="0" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Max Discount (₹)</label>
            <input type="number" name="maxDiscount" min="0" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Expiry Date*</label>
            <input type="date" name="expiryDate" required class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Usage Limit (total)</label>
            <input type="number" name="usageLimit" min="1" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" placeholder="Leave blank for unlimited">
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Per User Limit*</label>
            <input type="number" name="userUsageLimit" required min="1" value="1" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
          </div>
        </div>

        <div class="flex justify-end mt-6">
          <button type="button" onclick="closeAddCouponModal()" class="mr-2 px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300">
            Cancel
          </button>
          <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600">
            Create Coupon
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Edit Coupon Modal -->
<div id="editCouponModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full">
  <div class="relative top-20 mx-auto p-5 border w-[600px] shadow-lg rounded-md bg-white">
    <div class="mt-3">
      <h3 class="text-lg leading-6 font-medium text-gray-900">Edit Coupon</h3>
      <form id="editCouponForm" class="mt-4">
        <input type="hidden" name="id" id="editCouponId">

        <div class="grid grid-cols-2 gap-4">
          <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Coupon Code (cannot change)</label>
            <input type="text" id="editCode" disabled class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline bg-gray-100">
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Discount Type*</label>
            <select name="discountType" id="editDiscountType" required class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
              <option value="fixed">Fixed Amount</option>
              <option value="percentage">Percentage (%)</option>
            </select>
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Discount Value*</label>
            <input type="number" name="discountValue" id="editDiscountValue" required min="1" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Minimum Order (₹)*</label>
            <input type="number" name="minAmount" id="editMinAmount" required min="0" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Max Discount (₹)</label>
            <input type="number" name="maxDiscount" id="editMaxDiscount" min="0" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Expiry Date*</label>
            <input type="date" name="expiryDate" id="editExpiryDate" required class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Usage Limit (total)</label>
            <input type="number" name="usageLimit" id="editUsageLimit" min="1" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Per User Limit*</label>
            <input type="number" name="userUsageLimit" id="editUserUsageLimit" required min="1" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
          </div>
        </div>

        <div class="flex justify-end mt-6">
          <button type="button" onclick="closeEditCouponModal()" class="mr-2 px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300">
            Cancel
          </button>
          <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600">
            Save Changes
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- JavaScript -->
<script>
  // Open Add Coupon Modal
  function openAddCouponModal() {
    document.getElementById('createCouponForm').reset();
    document.getElementById('addCouponModal').classList.remove('hidden');
  }

  // Close Add Coupon Modal
  function closeAddCouponModal() {
    document.getElementById('addCouponModal').classList.add('hidden');
  }

  // Open Edit Coupon Modal
  function openEditCouponModal(id, code, discountType, discountValue, minAmount, maxDiscount, expiryDate, usageLimit, userUsageLimit) {
    document.getElementById('editCouponId').value = id;
    document.getElementById('editCode').value = code;
    document.getElementById('editDiscountType').value = discountType;
    document.getElementById('editDiscountValue').value = discountValue;
    document.getElementById('editMinAmount').value = minAmount;
    document.getElementById('editMaxDiscount').value = maxDiscount === 'null' ? '' : maxDiscount;
    document.getElementById('editExpiryDate').value = expiryDate;
    document.getElementById('editUsageLimit').value = usageLimit === 'null' ? '' : usageLimit;
    document.getElementById('editUserUsageLimit').value = userUsageLimit;

    document.getElementById('editCouponModal').classList.remove('hidden');
  }

  // Close Edit Coupon Modal
  function closeEditCouponModal() {
    document.getElementById('editCouponModal').classList.add('hidden');
  }

  // Create Coupon (AJAX)
  document.getElementById('createCouponForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData);

    try {
      const res = await fetch('/admin/coupons', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      const result = await res.json();
      if (result.success) {
        Swal.fire({
          icon: 'success',
          title: 'Success',
          text: result.message || 'Coupon created successfully!',
          timer: 1500
        }).then(() => {
          location.reload();
        });
      } else {
        Swal.fire('Error', result.message || 'Failed to create coupon', 'error');
      }
    } catch (err) {
      console.error('Create error:', err);
      Swal.fire('Error', err.message || 'Something went wrong', 'error');
    }
  });

  // Save edited coupon
  document.getElementById('editCouponForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = document.getElementById('editCouponForm');
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    const id = data.id;

    try {
      const res = await fetch(`/admin/coupons/${id}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      const result = await res.json();

      if (result.success) {
        Swal.fire({
          icon: 'success',
          title: 'Success',
          text: result.message || 'Coupon updated',
          timer: 1500
        }).then(() => {
          location.reload();
        });
      } else {
        Swal.fire('Error', result.message || 'Update failed', 'error');
      }
    } catch (err) {
      console.error('Save error:', err);
      Swal.fire('Error', err.message || 'Something went wrong', 'error');
    }
  });

  // Toggle Active Status
  async function toggleCoupon(id, shouldActivate) {
    const result = await Swal.fire({
      title: 'Are you sure?',
      text: `Are you sure you want to ${shouldActivate ? 'activate' : 'deactivate'} this coupon?`,
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#3085d6',
      cancelButtonColor: '#d33',
      confirmButtonText: 'Yes'
    });

    if (!result.isConfirmed) return;

    try {
      const res = await fetch(`/admin/coupons/${id}/toggle`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' }
      });

      const result = await res.json();
      if (result.success) {
        Swal.fire({
          icon: 'success',
          title: 'Success',
          text: result.message || 'Status updated',
          timer: 1500
        }).then(() => {
          location.reload();
        });
      } else {
        Swal.fire('Error', 'Failed to update status', 'error');
      }
    } catch (err) {
      Swal.fire('Error', err.message || 'Something went wrong', 'error');
    }
  }

  // Delete Coupon
  async function deleteCoupon(id) {
    const result = await Swal.fire({
      title: 'Are you sure?',
      text: 'Are you sure you want to delete this coupon? This action cannot be undone.',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#d33',
      cancelButtonColor: '#3085d6',
      confirmButtonText: 'Yes, delete it!'
    });

    if (!result.isConfirmed) return;

    try {
      const res = await fetch(`/admin/coupons/${id}`, { method: 'DELETE' });
      const result = await res.json();
      if (result.success) {
        Swal.fire({
          icon: 'success',
          title: 'Deleted',
          text: 'Coupon deleted successfully',
          timer: 1500
        }).then(() => {
          location.reload();
        });
      } else {
        Swal.fire('Error', 'Failed to delete coupon', 'error');
      }
    } catch (err) {
      Swal.fire('Error', err.message || 'Something went wrong', 'error');
    }
  }
</script>

<%- include('../partials/admin/footer') %>