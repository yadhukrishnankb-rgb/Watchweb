<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= status %> - <%= title || 'Admin Error' %></title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: Inter, system-ui, sans-serif; }
        body { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #111827; color: #f8fafc; }
        .card { width: min(680px, 100%); padding: 2.5rem; background: rgba(15, 23, 42, 0.95); border: 1px solid rgba(148, 163, 184, 0.2); border-radius: 24px; box-shadow: 0 24px 60px rgba(15, 23, 42, 0.35); }
        .status { font-size: 5rem; font-weight: 800; color: #38bdf8; }
        .heading { margin-top: 0.75rem; font-size: 2rem; font-weight: 800; }
        .subtext { margin-top: 1rem; color: #cbd5e1; line-height: 1.75; }
        .actions { margin-top: 2rem; display: flex; flex-wrap: wrap; gap: 0.75rem; }
        .btn { padding: 0.95rem 1.5rem; border-radius: 999px; font-weight: 700; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; transition: background 0.2s ease, transform 0.2s ease; }
        .btn-primary { background: #2563eb; color: white; }
        .btn-secondary { background: rgba(255, 255, 255, 0.08); color: #e2e8f0; }
        .btn:hover { transform: translateY(-2px); }
    </style>
</head>
<body>
    <div class="card">
        <div class="status"><%= status %></div>
        <div class="heading"><%= title || (status === 400 ? 'Bad Request' : status === 404 ? 'Page Not Found' : 'Server Error') %></div>
        <div class="subtext"><%= message || 'The admin panel encountered an error. Please try again or contact support.' %></div>
        <div class="actions">
            <a href="/admin" class="btn btn-primary">Admin Home</a>
            <a href="javascript:history.back()" class="btn btn-secondary">Go Back</a>
        </div>
    </div>
</body>
</html>
