<%- include('../partials/admin/header') %>

<div class="p-8 w-full">
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
    <div>
      <h2 class="text-3xl font-semibold text-gray-900">Brands</h2>
      <p class="text-sm text-gray-600 mt-1">Manage your brand list, block/unblock brands, or delete them.</p>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg p-5 mb-6">
    <form id="brandForm" class="flex flex-col sm:flex-row gap-3 items-start sm:items-center">
      <input id="brandName" name="name" type="text" placeholder="Enter brand" class="w-full sm:w-72 border border-gray-300 rounded-md px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-500" />
      <button type="submit" class="bg-green-600 text-white rounded-md px-5 py-2 hover:bg-green-700 transition">Add Brand</button>
    </form>
  </div>

  <div class="overflow-x-auto bg-white shadow rounded-lg">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% if (brands.length === 0) { %>
          <tr>
            <td colspan="3" class="px-6 py-4 text-center text-gray-500">No brands found.</td>
          </tr>
        <% } %>

        <% brands.forEach(b => { %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= b.name %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm <%= b.isBlocked ? 'text-red-600' : 'text-green-600' %>"><%= b.isBlocked ? 'Blocked' : 'Active' %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 space-x-2">
              <button type="button" data-action="toggle" data-id="<%= b._id %>" class="inline-flex items-center px-3 py-1.5 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
                <%= b.isBlocked ? 'Unblock' : 'Block' %>
              </button>
              <button type="button" data-action="delete" data-id="<%= b._id %>" data-name="<%= b.name %>" class="inline-flex items-center px-3 py-1.5 border border-red-300 rounded-md text-sm font-medium text-red-700 bg-white hover:bg-red-50">
                Delete
              </button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<script>
  const brandForm = document.getElementById('brandForm');
  const brandNameInput = document.getElementById('brandName');

  brandForm.addEventListener('submit', async (event) => {
    event.preventDefault();

    const brandName = brandNameInput.value.trim();
    if (!brandName) {
      Swal.fire({ icon: 'warning', title: 'Brand name required', text: 'Please enter a brand name.' });
      return;
    }

    try {
      const response = await fetch('/admin/add-brand', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: brandName })
      });

      const data = await response.json();
      if (data.success) {
        await Swal.fire({ icon: 'success', title: 'Brand Added', text: data.message, timer: 1400, showConfirmButton: false });
        window.location.reload();
      } else {
        Swal.fire({ icon: 'error', title: 'Could not add brand', text: data.message || 'Please try again.' });
      }
    } catch (error) {
      console.error('Add brand request failed:', error);
      Swal.fire({ icon: 'error', title: 'Server error', text: 'Unable to add brand right now.' });
    }
  });

  document.addEventListener('click', async (event) => {
    const button = event.target.closest('[data-action]');
    if (!button) return;

    const brandId = button.dataset.id;
    const action = button.dataset.action;

    if (action === 'toggle') {
      try {
        const response = await fetch(`/admin/toggle-brand/${brandId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const data = await response.json();
        if (data.success) {
          await Swal.fire({ icon: 'success', title: 'Updated', text: data.message, timer: 1300, showConfirmButton: false });
          window.location.reload();
        } else {
          Swal.fire({ icon: 'error', title: 'Unable to update', text: data.message || 'Please try again.' });
        }
      } catch (error) {
        console.error('Toggle brand failed:', error);
        Swal.fire({ icon: 'error', title: 'Server error', text: 'Unable to update brand status.' });
      }
    }

    if (action === 'delete') {
      const brandName = button.dataset.name || 'this brand';
      const result = await Swal.fire({
        title: `Delete ${brandName}?`,
        text: 'This action cannot be undone.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Delete',
        cancelButtonText: 'Cancel',
        reverseButtons: true
      });

      if (!result.isConfirmed) return;

      try {
        const response = await fetch(`/admin/brands/${brandId}`, { method: 'DELETE' });
        const data = await response.json();
        if (data.success) {
          await Swal.fire({ icon: 'success', title: 'Deleted', text: data.message, timer: 1400, showConfirmButton: false });
          window.location.reload();
        } else {
          Swal.fire({ icon: 'error', title: 'Delete failed', text: data.message || 'Please try again.' });
        }
      } catch (error) {
        console.error('Delete brand failed:', error);
        Swal.fire({ icon: 'error', title: 'Server error', text: 'Unable to delete brand.' });
      }
    }
  });
</script>

<%- include('../partials/admin/footer') %>