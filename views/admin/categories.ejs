<%- include('../partials/admin/header') %>

<style>
.error-message {
    display: none;
    margin-top: 0.5rem;
    padding: 0.55rem 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid #fecaca;
    background: #fef2f2;
    color: #991b1b;
    font-size: 0.9rem;
    line-height: 1.3;
}
.error-message.show {
    display: block;
}
.is-invalid {
    border-color: #dc2626 !important;
    box-shadow: 0 0 0 1px rgba(220, 38, 38, 0.25);
}
</style>

<div class="flex-1 p-8">
    <div class="mb-6 flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gray-800">Category Management</h1>
        <button onclick="openAddModal()" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600">
            Add Category
        </button>
    </div>

    <!-- Search Bar -->
    <div class="mb-6">
        <form action="/admin/categories" method="GET" class="flex gap-2">
            <input type="text" 
                   name="search" 
                   value="<%= searchQuery %>" 
                   placeholder="Search categories..." 
                   class="flex-1 px-4 py-2 border rounded-lg">
            <button type="submit" class="px-6 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600">
                Search
            </button>
            <% if (searchQuery) { %>
                <a href="/admin/categories" class="px-6 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600">
                    Clear
                </a>
            <% } %>
        </form>
    </div>

    <!-- Categories Table -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Description</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Offer</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Created At</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                <% if (categories && categories.length > 0) { %>
                    <% categories.forEach(category => { %>
                        <tr data-category-id="<%= category._id %>">
                            <td class="px-6 py-4 whitespace-nowrap"><%= category.name %></td>
                            <td class="px-6 py-4"><%= category.description %></td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <% if (category.offer && category.offer.percentage > 0) { %>
                                    <div class="text-sm text-green-600 font-semibold">
                                        <%= category.offer.percentage %>% OFF
                                    </div>
                                    <% if (category.offer.startDate && category.offer.endDate) { %>
                                        <div class="text-xs text-gray-500">
                                            <%= new Date(category.offer.startDate).toLocaleDateString() %> - 
                                            <%= new Date(category.offer.endDate).toLocaleDateString() %>
                                        </div>
                                    <% } %>
                                <% } else { %>
                                    <span class="text-gray-400">No offer</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <%= category.createdAt && !isNaN(new Date(category.createdAt)) ? new Date(category.createdAt).toLocaleDateString() : 'Invalid Date' %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <button onclick="openEditModal('<%= category._id %>', '<%= category.name %>', '<%= category.description %>')" 
                                        class="text-blue-600 hover:text-blue-900 mr-3">
                                    Edit
                                </button>
                                <button onclick="confirmDelete('<%= category._id %>')" 
                                        class="text-red-600 hover:text-red-900 mr-3">
                                    Delete
                                </button>
                                <% if (category.offer && category.offer.percentage > 0) { %>
                                    <button onclick="editOffer('<%= category._id %>', '<%= category.offer?.percentage %>', '<%= category.offer?.startDate %>', '<%= category.offer?.endDate %>')" class="text-blue-600 hover:text-blue-900 mr-3">
                                        Edit Offer
                                    </button>
                                    <button onclick="promptRemoveCategoryOffer('<%= category._id %>')" class="text-red-600 hover:text-red-900">
                                        Remove Offer
                                    </button>
                                <% } else { %>
                                    <button onclick="promptSetCategoryOffer('<%= category._id %>')" class="text-indigo-600 hover:text-indigo-900">
                                        Set Offer
                                    </button>
                                <% } %>
                            </td>
                        </tr>

                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="4" class="px-6 py-4 text-center text-gray-500">
                            No categories found
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
        <div class="mt-6 flex justify-center">
            <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px">
                <% for(let i = 1; i <= totalPages; i++) { %>
                    <a href="/admin/categories?page=<%= i %><%= searchQuery ? '&search=' + searchQuery : '' %>" 
                       class="relative inline-flex items-center px-4 py-2 border text-sm font-medium 
                              <%= currentPage === i ? 'z-10 bg-blue-50 border-blue-500 text-blue-600' : 'bg-white border-gray-300 text-gray-500 hover:bg-gray-50' %>">
                        <%= i %>
                    </a>
                <% } %>
            </nav>
        </div>
    <% } %>
</div>

<!-- Add Category Modal -->
<div id="addModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full">
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
        <div class="mt-3">
            <h3 class="text-lg leading-6 font-medium text-gray-900">Add New Category</h3>
            <form id="addCategoryForm" class="mt-4" novalidate>
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-bold mb-2">Name</label>
                    <input type="text" name="name" required
                           class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                    <div id="addNameError" class="error-message"></div>
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-bold mb-2">Description</label>
                    <textarea name="description" required
                              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"></textarea>
                    <div id="addDescriptionError" class="error-message"></div>
                </div>
                <div class="flex justify-end">
                    <button type="button" onclick="closeAddModal()" 
                            class="mr-2 px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300">
                        Cancel
                    </button>
                    <button type="submit" 
                            class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600">
                        Add
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Category Modal -->
<div id="editModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full">
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
        <div class="mt-3">
            <h3 class="text-lg leading-6 font-medium text-gray-900">Edit Category</h3>
            <form id="editCategoryForm" class="mt-4" novalidate>
                <input type="hidden" id="editCategoryId">
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-bold mb-2">Name</label>
                    <input type="text" id="editName" name="name" required
                           class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                    <div id="editNameError" class="error-message"></div>
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-bold mb-2">Description</label>
                    <textarea id="editDescription" name="description" required
                              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"></textarea>
                    <div id="editDescriptionError" class="error-message"></div>
                </div>
                <div class="flex justify-end">
                    <button type="button" onclick="closeEditModal()" 
                            class="mr-2 px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300">
                        Cancel
                    </button>
                    <button type="submit" 
                            class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600">
                        Update
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Offer Modal -->
<div id="editOfferModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full">
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
        <div class="mt-3">
            <h3 class="text-lg leading-6 font-medium text-gray-900">Edit Category Offer</h3>
            <form id="editOfferForm" class="mt-4" novalidate>
                <input type="hidden" id="editOfferCategoryId">
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-bold mb-2">Percentage</label>
                    <input type="number" id="editPercentage" name="percentage" min="0" max="100" required
                           class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                    <div id="editPercentageError" class="error-message"></div>
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-bold mb-2">Start Date</label>
                    <input type="date" id="editStartDate" name="startDate" required
                           class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                    <div id="editStartDateError" class="error-message"></div>
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-bold mb-2">End Date</label>
                    <input type="date" id="editEndDate" name="endDate" required
                           class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                    <div id="editEndDateError" class="error-message"></div>
                </div>
                <div class="flex justify-end">
                    <button type="button" onclick="closeEditOfferModal()" 
                            class="mr-2 px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300">
                        Cancel
                    </button>
                    <button type="submit" 
                            class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600">
                        Update
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
// Modal Functions
function openAddModal() {
    document.getElementById('addModal').classList.remove('hidden');
}

function closeAddModal() {
    document.getElementById('addModal').classList.add('hidden');
    document.getElementById('addCategoryForm').reset();
    clearErrors(['addNameError', 'addDescriptionError']);
}

function openEditModal(id, name, description) {
    document.getElementById('editModal').classList.remove('hidden');
    document.getElementById('editCategoryId').value = id;
    document.getElementById('editName').value = name;
    document.getElementById('editDescription').value = description;
    clearErrors(['editNameError', 'editDescriptionError']);
}

function closeEditModal() {
    document.getElementById('editModal').classList.add('hidden');
    document.getElementById('editCategoryForm').reset();
    clearErrors(['editNameError', 'editDescriptionError']);
}

function closeEditOfferModal() {
    document.getElementById('editOfferModal').classList.add('hidden');
    document.getElementById('editOfferForm').reset();
    clearErrors(['editPercentageError', 'editStartDateError', 'editEndDateError']);
}

// Validation helpers
function setFieldError(fieldId, message) {
    const field = document.getElementById(fieldId);
    if (!field) return;
    field.innerHTML = `
        <span class="inline-flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm.75 5.75a.75.75 0 00-1.5 0v5.5a.75.75 0 001.5 0v-5.5zm0 9a.75.75 0 00-1.5 0 .75.75 0 001.5 0z" clip-rule="evenodd" />
            </svg>
            <span>${message}</span>
        </span>
    `;
    field.classList.add('show');
    const input = field.closest('.mb-4')?.querySelector('input, textarea');
    if (input) input.classList.add('is-invalid');
}

function clearFieldError(fieldId) {
    const field = document.getElementById(fieldId);
    if (!field) return;
    field.innerHTML = '';
    field.classList.remove('show');
    const input = field.closest('.mb-4')?.querySelector('input, textarea');
    if (input) input.classList.remove('is-invalid');
}

function clearErrors(fieldIds) {
    fieldIds.forEach(clearFieldError);
}

// Form Submissions
function validateCategoryForm(prefix) {
    const name = document.querySelector(`#${prefix}CategoryForm [name="name"]`).value.trim();
    const description = document.querySelector(`#${prefix}CategoryForm [name="description"]`).value.trim();
    const errors = [];
    clearErrors([`${prefix}NameError`, `${prefix}DescriptionError`]);

    if (!name) {
        errors.push('Name is required.');
        setFieldError(`${prefix}NameError`, 'Name is required.');
    }
    if (!description) {
        errors.push('Description is required.');
        setFieldError(`${prefix}DescriptionError`, 'Description is required.');
    }

    if (errors.length) {
        return false;
    }
    return true;
}

['addCategoryForm', 'editCategoryForm', 'editOfferForm'].forEach((formId) => {
    const form = document.getElementById(formId);
    if (!form) return;
    form.querySelectorAll('input,textarea').forEach((element) => {
        element.addEventListener('input', () => {
            switch (formId) {
                case 'addCategoryForm':
                    clearErrors(['addNameError', 'addDescriptionError']);
                    break;
                case 'editCategoryForm':
                    clearErrors(['editNameError', 'editDescriptionError']);
                    break;
                case 'editOfferForm':
                    clearErrors(['editPercentageError', 'editStartDateError', 'editEndDateError']);
                    break;
            }
        });
    });
});

document.getElementById('addCategoryForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!validateCategoryForm('add')) return;
    const formData = new FormData(e.target);
    clearErrors(['addNameError', 'addDescriptionError']);
    
    try {
        const response = await fetch('/admin/categories', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                name: formData.get('name'),
                description: formData.get('description')
            })
        });
        
        const data = await response.json();
        
        if (data.success) {
            closeAddModal();
            window.location.reload();
        } else {
            setFieldError('addNameError', data.message || 'Error adding category.');
        }
    } catch (error) {
        setFieldError('addNameError', 'Error adding category.');
    }
});

document.getElementById('editCategoryForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!validateCategoryForm('edit')) return;
    const id = document.getElementById('editCategoryId').value;
    const formData = new FormData(e.target);
    clearErrors(['editNameError', 'editDescriptionError']);
    
    try {
        const response = await fetch(`/admin/categories/${id}`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                name: formData.get('name'),
                description: formData.get('description')
            })
        });
        
        const data = await response.json();
        
        if (data.success) {
            closeEditModal();
            window.location.reload();
        } else {
            setFieldError('editNameError', data.message || 'Error updating category.');
        }
    } catch (error) {
        setFieldError('editNameError', 'Error updating category.');
    }
});

document.getElementById('editOfferForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const percentage = document.getElementById('editPercentage').value.trim();
    const startDate = document.getElementById('editStartDate').value;
    const endDate = document.getElementById('editEndDate').value;
    const id = document.getElementById('editOfferCategoryId').value;

    clearErrors(['editPercentageError', 'editStartDateError', 'editEndDateError']);
    const errors = [];

    if (!percentage) {
        errors.push('Percentage is required.');
        setFieldError('editPercentageError', 'Percentage is required.');
    } else if (isNaN(Number(percentage)) || Number(percentage) < 0 || Number(percentage) > 100) {
        errors.push('Percentage must be between 0 and 100.');
        setFieldError('editPercentageError', 'Percentage must be between 0 and 100.');
    }

    if (!startDate) {
        errors.push('Start date is required.');
        setFieldError('editStartDateError', 'Start date is required.');
    }
    if (!endDate) {
        errors.push('End date is required.');
        setFieldError('editEndDateError', 'End date is required.');
    }
    if (startDate && endDate && new Date(startDate) > new Date(endDate)) {
        errors.push('End date must be after start date.');
        setFieldError('editEndDateError', 'End date must be after start date.');
    }

    if (errors.length) {
        return;
    }

    try {
        const response = await fetch(`/admin/categories/${id}/offer`, {
            method: 'PATCH',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                percentage: Number(percentage),
                startDate,
                endDate
            })
        });
        
        const data = await response.json();
        
        if (data.success) {
            closeEditOfferModal();
            window.location.reload();
        } else {
            setFieldError('editPercentageError', data.message || 'Error updating offer.');
        }
    } catch (error) {
        setFieldError('editPercentageError', 'Error updating offer.');
    }
});

function confirmDelete(id) {
    Swal.fire({
        title: 'Are you sure?',
        text: "You won't be able to revert this!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#3085d6',
        cancelButtonColor: '#d33',
        confirmButtonText: 'Yes, delete it!'
    }).then((result) => {
        if (result.isConfirmed) {
            deleteCategory(id);
        }
    });
}



async function deleteCategory(id) {
    try {
        const response = await fetch(`/admin/categories/${id}`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json'
            }
        });
        
        const data = await response.json();
        
        if (data.success) {
            Swal.fire({
                icon: 'success',
                title: 'Deleted!',
                text: 'Category has been deleted.',
                showConfirmButton: false,
                timer: 1500
            }).then(() => {
                // Remove the deleted row from the table without page reload
                const row = document.querySelector(`tr[data-category-id="${id}"]`);
                if (row) {
                    row.remove();
                }
                // If no categories left, show "No categories found" message
                const tbody = document.querySelector('tbody');
                if (!tbody.hasChildNodes()) {
                    tbody.innerHTML = `
                        <tr>
                            <td colspan="4" class="px-6 py-4 text-center text-gray-500">
                                No categories found
                            </td>
                        </tr>
                    `;
                }
            });
        } else {
            Swal.fire({
                icon: 'error',
                title: 'Oops...',
                text: data.message || 'Something went wrong!'
            });
        }
    } catch (error) {
        Swal.fire({
            icon: 'error',
            title: 'Oops...',
            text: 'Error deleting category!'
        });
    }
}


// ===== offer dialogs =====
async function promptSetCategoryOffer(categoryId) {
  const { value: formValues } = await Swal.fire({
    title: 'Set Category Offer',
    html: `
      <input type="number" id="offerInput" class="swal2-input" placeholder="Percentage (0-100)" min="0" max="100">
      <input type="date" id="startInput" class="swal2-input" placeholder="Start date">
      <input type="date" id="endInput" class="swal2-input" placeholder="End date">
    `,
    focusConfirm: false,
    showCancelButton: true,
    confirmButtonText: 'Set Offer',
    preConfirm: () => {
      const offerVal = Number(document.getElementById('offerInput').value);
      const startVal = document.getElementById('startInput').value;
      const endVal = document.getElementById('endInput').value;
      
      if (isNaN(offerVal) || offerVal < 0 || offerVal > 100) {
        Swal.showValidationMessage('Percentage must be 0-100');
        return;
      }
      if (!startVal || !endVal) {
        Swal.showValidationMessage('Please select both dates');
        return;
      }
      if (new Date(startVal) > new Date(endVal)) {
        Swal.showValidationMessage('End date must be after start date');
        return;
      }
      return { percentage: offerVal, startDate: startVal, endDate: endVal };
    }
  });

  if (!formValues) return;

  try {
    const response = await fetch(`/admin/categories/${categoryId}/offer`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(formValues)
    });
    const data = await response.json();
    
    if (data.success) {
      Swal.fire({ icon: 'success', title: 'Offer Set!', timer: 1500 })
        .then(() => location.reload());
    } else {
      Swal.fire({ icon: 'error', title: 'Error', text: data.message });
    }
  } catch (err) {
    Swal.fire({ icon: 'error', title: 'Error', text: err.message });
  }
}

async function promptRemoveCategoryOffer(categoryId) {
  const res = await Swal.fire({
    title: 'Remove Offer?',
    text: 'This will remove the category discount.',
    icon: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Remove',
    cancelButtonText: 'Keep'
  });

  if (!res.isConfirmed) return;

  try {
    const response = await fetch(`/admin/categories/${categoryId}/offer/remove`, {
      method: 'PATCH'
    });
    const data = await response.json();
    
    if (data.success) {
      Swal.fire({ icon: 'success', title: 'Removed!', timer: 1500 })
        .then(() => location.reload());
    } else {
      Swal.fire({ icon: 'error', title: 'Error', text: data.message });
    }
  } catch (err) {
    Swal.fire({ icon: 'error', title: 'Error', text: err.message });
  }
}


function editOffer(id, percentage, startDate, endDate) {
    document.getElementById('editOfferModal').classList.remove('hidden');
    document.getElementById('editOfferCategoryId').value = id;
    document.getElementById('editPercentage').value = percentage;
    document.getElementById('editStartDate').value = startDate ? new Date(startDate).toISOString().split('T')[0] : '';
    document.getElementById('editEndDate').value = endDate ? new Date(endDate).toISOString().split('T')[0] : '';
}

</script>




<%- include('../partials/admin/footer') %>